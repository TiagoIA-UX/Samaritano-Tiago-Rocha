# Samaritano — variáveis de ambiente (template seguro para commit)
# Copie para .env.local e preencha suas chaves:
#   copy .env.example .env.local

# Provider: groq | openai | gemini | anthropic | deepseek | openrouter | ollama | auto
SAMARITANO_PROVIDER=groq

# API keys (preencha só o provider que for usar)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local, sem chave real)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Servidor (opcional)
# PORT=5070
# PORT_HTTPS=5071
# SAMARITANO_BIND_LAN=0
# SAMARITANO_DISABLE_HTTPS=0
# LOG_LEVEL=info
# DATA_DIR=./data

# Voz OpenAI (opcional)
# OPENAI_VOICE=nova
